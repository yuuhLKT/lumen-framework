{
    "name": "study/php-base",
    "description": "Base PHP simples e generica para APIs, estudos e desafios backend.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "utils/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse app routes public bootstrap tools --level=5 --memory-limit=512M",
        "format": "php-cs-fixer fix --allow-risky=yes",
        "format-check": "php-cs-fixer fix --allow-risky=yes --dry-run --diff",
        "lint": "php tools/lint.php",
        "migrate": "php tools/migrate.php",
        "seed": "php tools/seed.php"
    },
    "config": {
        "sort-packages": true
    }
}
